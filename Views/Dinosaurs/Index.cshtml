@model IEnumerable<DinoApp.Models.DinosaurDto>

@{
    ViewData["Title"] = "Динозавры";
}

<style>
    /* Основные стили в стиле Dino_Mir */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #1a472a 0%, #2d5a3b 100%);
        min-height: 100vh;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    /* Заголовок в стиле главной */
    .hero-section {
        text-align: center;
        padding: 60px 20px 40px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 30px;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        border: 2px solid #ffd700;
    }

        .hero-section h1 {
            font-size: 48px;
            color: #2c5a1e;
            margin-bottom: 15px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

            .hero-section h1 span {
                display: inline-block;
                transition: transform 0.3s ease;
            }

            .hero-section h1:hover span {
                transform: rotate(15deg);
            }

        .hero-section p {
            font-size: 20px;
            color: #555;
            margin-bottom: 30px;
        }

    /* Кнопки в стиле главной */
    .btn-group-main {
        display: flex;
        gap: 20px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-dino {
        padding: 12px 30px;
        font-size: 18px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        font-weight: bold;
    }

    .btn-map {
        background-color: #ffd700;
        color: #2c5a1e;
        box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
    }

        .btn-map:hover {
            background-color: #ffed4a;
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 215, 0, 0.4);
        }

    .btn-find {
        background-color: #ff6b35;
        color: white;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
    }

        .btn-find:hover {
            background-color: #ff8555;
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
        }

    .btn-add {
        background-color: #4caf50;
        color: white;
        padding: 12px 25px;
        font-size: 16px;
    }

        .btn-add:hover {
            background-color: #45a049;
            transform: translateY(-2px);
        }

    /* Карточки динозавров */
    .dino-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 30px;
        margin-top: 30px;
    }

    .dino-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
        transition: all 0.3s ease;
        cursor: pointer;
        border: 1px solid rgba(255, 215, 0, 0.3);
    }

        .dino-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            border-color: #ffd700;
        }

    .dino-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
        background: linear-gradient(135deg, #e8d5b7, #d4c4a8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
        transition: transform 0.3s ease;
    }

    .dino-card:hover .dino-image {
        transform: scale(1.05);
    }

    .dino-info {
        padding: 20px;
    }

    .dino-name {
        font-size: 28px;
        color: #2c5a1e;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .era-badge {
        display: inline-block;
        padding: 5px 12px;
        background: linear-gradient(135deg, #ffd700, #ffed4a);
        color: #2c5a1e;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
    }

    .dino-detail {
        margin: 10px 0;
        color: #555;
        font-size: 14px;
    }

        .dino-detail strong {
            color: #2c5a1e;
            font-weight: 600;
        }

    .description {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #eee;
        font-size: 14px;
        line-height: 1.5;
        color: #666;
    }

    /* Кнопки действий */
    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px solid #eee;
    }

    .btn-sm {
        padding: 8px 16px;
        font-size: 13px;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-view {
        background: #2196f3;
        color: white;
    }

        .btn-view:hover {
            background: #0b7dda;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: #ff9800;
        color: white;
    }

        .btn-edit:hover {
            background: #e68900;
            transform: translateY(-2px);
        }

    .btn-delete {
        background: #f44336;
        color: white;
    }

        .btn-delete:hover {
            background: #da190b;
            transform: translateY(-2px);
        }

    /* Уведомления */
    .alert {
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        font-weight: 500;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border-left: 5px solid #28a745;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        border-left: 5px solid #dc3545;
    }

    /* Пустое состояние */
    .empty-state {
        text-align: center;
        padding: 60px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 30px;
        margin-top: 40px;
    }

        .empty-state h2 {
            font-size: 32px;
            color: #2c5a1e;
            margin-bottom: 15px;
        }

        .empty-state p {
            color: #666;
            font-size: 18px;
        }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .hero-section h1 {
            font-size: 32px;
        }

        .hero-section p {
            font-size: 16px;
        }

        .dino-grid {
            grid-template-columns: 1fr;
        }

        .btn-group-main {
            flex-direction: column;
            align-items: center;
        }

        .btn-dino {
            width: 80%;
            text-align: center;
        }
    }
</style>

<div class="container">
    <!-- Шапка в стиле главной страницы -->
    <div class="hero-section">
        <h1>
            🦕 <span>Dino_Mir</span> 🦖
        </h1>
        <p>Всё о динозаврах в одном месте!</p>
        <div class="btn-group-main">
            <a asp-action="Map" class="btn-dino btn-map">🗺️ Перейти на карту Диномира</a>
        </div>
    </div>

    <!-- Заголовок раздела динозавров -->
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; margin-bottom: 25px;">
        <h2 style="color: white; font-size: 32px; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">
            🦕 Наши динозавры
        </h2>
        <a asp-action="Create" class="btn-dino btn-add">➕ Добавить динозавра</a>
    </div>

    <!-- Уведомления -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            ✅ @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            ❌ @TempData["ErrorMessage"]
        </div>
    }

    <!-- Список динозавров -->
    @if (!Model.Any())
    {
        <div class="empty-state">
            <h2>😕 Пока нет динозавров</h2>
            <p>Нажмите кнопку "Добавить динозавра", чтобы создать первого!</p>
        </div>
    }
    else
    {
        <div class="dino-grid">
            @foreach (var dino in Model)
            {
                <div class="dino-card">
                    @{
                        var imageUrl = !string.IsNullOrEmpty(dino.PhotoPath) ? dino.PhotoPath : dino.PhotoUrl;
                    }

                    @if (!string.IsNullOrEmpty(imageUrl))
                    {
                        <img src="@imageUrl"
                             alt="@dino.Name"
                             class="dino-image"
                             onerror="this.onerror=null; this.src='/images/default-dino.jpg';"
                             data-original-src="@imageUrl" />
                    }
                    else
                    {
                        <div class="dino-image">
                            🦕
                        </div>
                    }

                    <div class="dino-info">
                        <div class="dino-name">
                            @dino.Name
                            @if (!string.IsNullOrEmpty(dino.Era))
                            {
                                <span class="era-badge">@dino.Era</span>
                            }
                        </div>

                        <div class="dino-detail">
                            <strong>Клада:</strong> @(dino.Clade ?? "Не указано")
                        </div>

                        <div class="dino-detail">
                            <strong>Период:</strong> @(dino.Period ?? "Не указан")
                        </div>

                        <div class="dino-detail">
                            <strong>Семейство:</strong> @(dino.GroupName ?? "Не указано")
                        </div>

                        @if (!string.IsNullOrEmpty(dino.Description))
                        {
                            <div class="description">
                                <strong>📖 Описание:</strong><br>
                                @(dino.Description.Length > 100
                                    ? dino.Description.Substring(0, 100) + "..."
                                    : dino.Description)
                            </div>
                        }

                        <div class="action-buttons">
                            <a asp-action="Details" asp-route-id="@dino.Id" class="btn-sm btn-view">👁️ Подробнее</a>
                            <a asp-action="Edit" asp-route-id="@dino.Id" class="btn-sm btn-edit">✏️ Редактировать</a>
                            <a asp-action="Delete" asp-route-id="@dino.Id" class="btn-sm btn-delete">🗑️ Удалить</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        console.log('=== Dino_Mir - Страница динозавров ===');

        @foreach (var dino in Model)
        {
            <text>
                    console.log('🦕 @dino.Name | Фото: @(dino.PhotoPath ?? dino.PhotoUrl ?? "Нет")');
            </text>
        }

            // Обработка ошибок изображений
            document.querySelectorAll('img').forEach(function (img) {
                img.addEventListener('error', function () {
                    console.warn('Не удалось загрузить:', this.src);
                    this.style.display = 'none';
                    var placeholder = document.createElement('div');
                    placeholder.className = 'dino-image';
                    placeholder.innerHTML = '🦕';
                    this.parentNode.insertBefore(placeholder, this);
                    this.remove();
                });
            });

        console.log('=== Страница готова ===');
    </script>
}