@* Views/Dinosaurs/Edit.cshtml *@
@model DinoApp.Models.DinosaurDto

@{
    ViewData["Title"] = $"Редактирование: {Model.Name}";
}

<style>
    /* стили остаются теми же */
    /* ... */
</style>

<div class="edit-container">
    <!-- Шапка -->
    <div class="page-header">
        <div class="header-icon">
            ✏️
        </div>
        <div class="header-title">
            <h1>Редактирование динозавра</h1>
            <p>ID: @Model.Id · <strong>@Model.Name</strong> <span class="status-badge">Редактирование</span></p>
        </div>
    </div>

    <div class="edit-form">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary" style="display: block; background-color: #fdeded; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                    ⚠️ Пожалуйста, исправьте ошибки в форме
                </div>
            }

            <!-- Основная информация -->
            <div class="form-card">
                <h3>📋 Основная информация</h3>

                <div class="form-group">
                    <label asp-for="Name" class="form-label">
                        <i>🦕</i> Название динозавра *
                    </label>
                    <input asp-for="Name" class="form-control">
                    <span asp-validation-for="Name" class="field-validation" style="color: #e74c3c;"></span>
                    <div class="help-text">
                        <i>ℹ️</i> Научное или популярное название
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i>⏳</i> Геологическая эра *
                    </label>
                    <div class="era-options">
                        <div class="era-option triassic">
                            <input type="radio" name="Era" id="triassic" value="Триасовый" @(Model.Era == "Триасовый" ? "checked" : "")>
                            <label for="triassic">Триасовый</label>
                        </div>
                        <div class="era-option jurassic">
                            <input type="radio" name="Era" id="jurassic" value="Юрский" @(Model.Era == "Юрский" ? "checked" : "")>
                            <label for="jurassic">Юрский</label>
                        </div>
                        <div class="era-option cretaceous">
                            <input type="radio" name="Era" id="cretaceous" value="Меловой" @(Model.Era == "Меловой" ? "checked" : "")>
                            <label for="cretaceous">Меловой</label>
                        </div>
                    </div>
                    <span asp-validation-for="Era" class="field-validation" style="color: #e74c3c;"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Clade" class="form-label">
                            <i>🔬</i> Клада
                        </label>
                        <select asp-for="Clade" class="select-control">
                            <option value="">Выберите кладу</option>
                            <option value="Ящеротазовые">Ящеротазовые (Saurischia)</option>
                            <option value="Птицетазовые">Птицетазовые (Ornithischia)</option>
                            <option value="Тероподы">Тероподы (Theropoda)</option>
                            <option value="Завроподоморфы">Завроподоморфы (Sauropodomorpha)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="Period" class="form-label">
                            <i>📅</i> Период
                        </label>
                        <input asp-for="Period" class="form-control">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="GroupName" class="form-label">
                            <i>👪</i> Семейство
                        </label>
                        <input asp-for="GroupName" class="form-control">
                    </div>

                    <div class="form-group">
                        <label asp-for="Size" class="form-label">
                            <i>📏</i> Размер
                        </label>
                        <select asp-for="Size" class="select-control">
                            <option value="">Выберите размер</option>
                            <option value="small">Маленький (до 2 м)</option>
                            <option value="medium">Средний (2-6 м)</option>
                            <option value="large">Крупный (6-12 м)</option>
                            <option value="huge">Гигантский (более 12 м)</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Фотография -->
            <div class="form-card">
                <h3>📸 Фотография</h3>

                <div class="photo-section">
                    <div class="current-photo" id="currentPhoto">
                        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                        {
                            <img src="@Model.PhotoUrl" alt="@Model.Name">
                        }
                        else
                        {
                            <span>🦕</span>
                        }
                    </div>
                    <div class="photo-input">
                        <div class="form-group">
                            <label asp-for="PhotoUrl" class="form-label">
                                <i>🔗</i> URL изображения
                            </label>
                            <input asp-for="PhotoUrl" class="form-control" id="photoUrl">
                            <div class="help-text">
                                <i>ℹ️</i> Ссылка на изображение динозавра
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Описание -->
            <div class="form-card">
                <h3>📝 Описание</h3>

                <div class="form-group">
                    <label asp-for="Description" class="form-label">
                        <i>📋</i> Краткое описание
                    </label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="form-group">
                    <label asp-for="FullDescription" class="form-label">
                        <i>📖</i> Полное описание
                    </label>
                    <textarea asp-for="FullDescription" class="form-control" rows="5"></textarea>
                    <div class="help-text">
                        <i>ℹ️</i> Подробное описание, особенности, образ жизни
                    </div>
                </div>
            </div>

            <!-- Дополнительная информация -->
            <div class="form-card">
                <h3>🔬 Дополнительная информация</h3>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Diet" class="form-label">
                            <i>🍖</i> Тип питания
                        </label>
                        <select asp-for="Diet" class="select-control">
                            <option value="carnivore">Хищник</option>
                            <option value="herbivore">Травоядный</option>
                            <option value="omnivore">Всеядный</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="Locomotion" class="form-label">
                            <i>🏃</i> Передвижение
                        </label>
                        <select asp-for="Locomotion" class="select-control">
                            <option value="bipedal">Двуногий</option>
                            <option value="quadrupedal">Четвероногий</option>
                            <option value="both">И так, и так</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Continent" class="form-label">
                            <i>🌍</i> Континент
                        </label>
                        <input asp-for="Continent" class="form-control">
                    </div>

                    <div class="form-group">
                        <label asp-for="DiscoveryLocation" class="form-label">
                            <i>🔍</i> Место обнаружения
                        </label>
                        <input asp-for="DiscoveryLocation" class="form-control">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Status" class="form-label">
                            <i>📊</i> Статус
                        </label>
                        <select asp-for="Status" class="select-control">
                            <option value="published">Опубликовано</option>
                            <option value="draft">Черновик</option>
                            <option value="archived">В архиве</option>
                        </select>
                    </div>
                </div>

                <div class="checkbox-group">
                    <div class="checkbox-item">
                        <input asp-for="IsFeatured" type="checkbox" id="IsFeatured">
                        <label for="IsFeatured">Показывать на главной</label>
                    </div>
                    <div class="checkbox-item">
                        <input asp-for="AllowComments" type="checkbox" id="AllowComments">
                        <label for="AllowComments">Разрешить комментарии</label>
                    </div>
                </div>
            </div>

            <!-- Кнопки -->
            <div class="form-actions">
                <button type="submit" class="btn btn-save">
                    💾 Сохранить изменения
                </button>
                <a asp-action="Index" class="btn btn-cancel">
                    ↩️ Отмена
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-delete">
                    🗑️ Удалить
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Предпросмотр фото при изменении URL
            const photoInput = document.getElementById('photoUrl');
            const currentPhoto = document.getElementById('currentPhoto');

            if (photoInput && currentPhoto) {
                photoInput.addEventListener('input', function (e) {
                    const url = e.target.value;
                    if (url && (url.startsWith('http') || url.startsWith('https'))) {
                        currentPhoto.innerHTML = `<img src="${url}" alt="Preview" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">`;
                    } else if (!url) {
                        currentPhoto.innerHTML = '<span>🦕</span>';
                    }
                });
            }
        });
    </script>
}