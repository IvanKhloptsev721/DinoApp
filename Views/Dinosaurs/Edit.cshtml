@* Views/Dinosaurs/Edit.cshtml *@
@model DinoApp.Models.DinosaurDto

@{
    ViewData["Title"] = $"Редактирование: {Model.Name}";
}

<!-- Стили остаются теми же -->

<div class="edit-container">
    <div class="page-header">
        <div class="header-icon">
            ✏️
        </div>
        <div class="header-title">
            <h1>Редактирование динозавра</h1>
            <p>ID: @Model.Id · <strong>@Model.Name</strong> <span class="status-badge">Редактирование</span></p>
        </div>
    </div>

    <div class="edit-form">
        <!-- ВАЖНО: Добавляем enctype="multipart/form-data" -->
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <!-- Скрытое поле для существующего пути к фото -->
            <input type="hidden" name="ExistingPhotoPath" value="@Model.PhotoPath" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary" style="display: block;">
                    ⚠️ Пожалуйста, исправьте ошибки в форме
                </div>
            }

            <!-- Остальные поля формы остаются -->
            <!-- Фотография - ИЗМЕНЕНО -->
            <div class="form-card">
                <h3>📸 Фотография</h3>

                <div class="photo-section">
                    <div class="current-photo" id="currentPhoto">
                        @if (!string.IsNullOrEmpty(Model.PhotoPath))
                        {
                            <img src="@Model.PhotoPath" alt="@Model.Name">
                        }
                        else
                        {
                            <span>🦕</span>
                        }
                    </div>
                    <div class="photo-input">
                        <div class="form-group">
                            <label asp-for="PhotoFile" class="form-label">
                                <i>📸</i> Загрузить новое фото
                            </label>
                            <input asp-for="PhotoFile" type="file" class="form-control" accept="image/*" id="photoFile">
                            <span asp-validation-for="PhotoFile" class="field-validation"></span>
                            <div class="help-text">
                                <i>ℹ️</i> Оставьте пустым, чтобы сохранить текущее фото
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Остальные поля формы остаются -->
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Предпросмотр нового фото
            const photoInput = document.getElementById('photoFile');
            const currentPhoto = document.getElementById('currentPhoto');

            if (photoInput && currentPhoto) {
                photoInput.addEventListener('change', function (e) {
                    const file = e.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            currentPhoto.innerHTML = `<img src="${e.target.result}" alt="Preview" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">`;
                        }
                        reader.readAsDataURL(file);
                    }
                });
            }
        });
    </script>
}