@* Views/Dinosaurs/CreateDinosaurs.cshtml *@
@model DinoApp.Models.CreateDinosaurDto

@{
    ViewData["Title"] = "Создание динозавра";
}

<style>
    /* стили остаются теми же */
    /* ... */
</style>

<div class="create-container">
    <div class="page-header">
        <div class="dino-avatar">
            🦖
        </div>
        <h1>👷 Создание нового динозавра</h1>
    </div>

    <div class="form-card">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary" style="display: block;">
                ⚠️ Пожалуйста, исправьте ошибки в форме
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <!-- Основная информация -->
            <div class="form-group">
                <label asp-for="Name" class="form-label">
                    <i>🦕</i> Имя динозавра *
                </label>
                <input asp-for="Name" class="form-control" placeholder="Например: Тираннозавр, Стегозавр, Трицератопс">
                <span asp-validation-for="Name" class="field-validation"></span>
                <div class="tooltip-info">
                    <i>ℹ️</i> Введите научное или популярное название динозавра
                </div>
            </div>

            <!-- Эра (радио кнопки) -->
            <div class="form-group">
                <label class="form-label">
                    <i>⏳</i> Геологическая эра *
                </label>
                <div class="era-options">
                    <div class="era-option triassic">
                        <input type="radio" name="Era" id="triassic" value="Триасовый" @(Model?.Era == "Триасовый" ? "checked" : "")>
                        <label for="triassic">Триасовый период</label>
                    </div>
                    <div class="era-option jurassic">
                        <input type="radio" name="Era" id="jurassic" value="Юрский" @(Model?.Era == "Юрский" ? "checked" : "")>
                        <label for="jurassic">Юрский период</label>
                    </div>
                    <div class="era-option cretaceous">
                        <input type="radio" name="Era" id="cretaceous" value="Меловой" @(Model?.Era == "Меловой" ? "checked" : "")>
                        <label for="cretaceous">Меловой период</label>
                    </div>
                </div>
                <span asp-validation-for="Era" class="field-validation"></span>
            </div>

            <!-- Две колонки -->
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Clade" class="form-label">
                        <i>🔬</i> Клада
                    </label>
                    <select asp-for="Clade" class="select-control">
                        <option value="">Выберите кладу</option>
                        <option value="Ящеротазовые">Ящеротазовые (Saurischia)</option>
                        <option value="Птицетазовые">Птицетазовые (Ornithischia)</option>
                        <option value="Тероподы">Тероподы (Theropoda)</option>
                        <option value="Завроподоморфы">Завроподоморфы (Sauropodomorpha)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Period" class="form-label">
                        <i>📅</i> Период
                    </label>
                    <input asp-for="Period" class="form-control" placeholder="Например: 150-145 млн лет назад">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="GroupName" class="form-label">
                        <i>👪</i> Семейство
                    </label>
                    <input asp-for="GroupName" class="form-control" placeholder="Например: Tyrannosauridae">
                </div>

                <div class="form-group">
                    <label asp-for="Size" class="form-label">
                        <i>📏</i> Размер
                    </label>
                    <select asp-for="Size" class="select-control">
                        <option value="">Выберите размер</option>
                        <option value="small">Маленький (до 2 м)</option>
                        <option value="medium">Средний (2-6 м)</option>
                        <option value="large">Крупный (6-12 м)</option>
                        <option value="huge">Гигантский (более 12 м)</option>
                    </select>
                </div>
            </div>

            <!-- Загрузка фото -->
            <div class="form-group">
                <label asp-for="PhotoUrl" class="form-label">
                    <i>📸</i> Фотография
                </label>
                <input asp-for="PhotoUrl" class="form-control" placeholder="URL изображения" id="photoUrl">

                <div class="photo-preview" id="photoPreview">
                    <div class="photo-placeholder">
                        <span>🖼️</span>
                        Предпросмотр фото будет здесь
                    </div>
                </div>
                <div class="tooltip-info">
                    <i>ℹ️</i> Укажите ссылку на изображение динозавра
                </div>
            </div>

            <!-- Описание -->
            <div class="form-group">
                <label asp-for="Description" class="form-label">
                    <i>📝</i> Краткое описание
                </label>
                <textarea asp-for="Description" class="form-control" placeholder="Краткое описание динозавра..."></textarea>
            </div>

            <!-- Полное описание -->
            <div class="form-group">
                <label asp-for="FullDescription" class="form-label">
                    <i>📖</i> Полное описание
                </label>
                <textarea asp-for="FullDescription" class="form-control" placeholder="Подробное описание динозавра..." rows="5"></textarea>
                <div class="character-counter" id="charCounter">
                    0 / 2000 символов
                </div>
            </div>

            <!-- Дополнительные характеристики -->
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Diet" class="form-label">
                        <i>🍖</i> Тип питания
                    </label>
                    <select asp-for="Diet" class="select-control">
                        <option value="carnivore">Хищник</option>
                        <option value="herbivore">Травоядный</option>
                        <option value="omnivore">Всеядный</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="Locomotion" class="form-label">
                        <i>🏃</i> Способ передвижения
                    </label>
                    <select asp-for="Locomotion" class="select-control">
                        <option value="bipedal">Двуногий</option>
                        <option value="quadrupedal">Четвероногий</option>
                        <option value="both">И так, и так</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Continent" class="form-label">
                        <i>🌍</i> Континент
                    </label>
                    <input asp-for="Continent" class="form-control" placeholder="Где обитал?">
                </div>

                <div class="form-group">
                    <label asp-for="DiscoveryLocation" class="form-label">
                        <i>🔍</i> Место обнаружения
                    </label>
                    <input asp-for="DiscoveryLocation" class="form-control" placeholder="Где нашли останки?">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Status" class="form-label">
                        <i>📊</i> Статус
                    </label>
                    <select asp-for="Status" class="select-control">
                        <option value="published">Опубликовано</option>
                        <option value="draft">Черновик</option>
                        <option value="archived">В архиве</option>
                    </select>
                </div>

                <div class="checkbox-group" style="display: flex; gap: 20px; align-items: center; margin-top: 30px;">
                    <div class="checkbox-item">
                        <input asp-for="IsFeatured" type="checkbox" id="IsFeatured">
                        <label for="IsFeatured">Показывать на главной</label>
                    </div>
                    <div class="checkbox-item">
                        <input asp-for="AllowComments" type="checkbox" id="AllowComments">
                        <label for="AllowComments">Разрешить комментарии</label>
                    </div>
                </div>
            </div>

            <!-- Кнопки действий -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    💾 Создать динозавра
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    ↩️ Отмена
                </a>
                <button type="reset" class="btn btn-danger">
                    🗑️ Очистить
                </button>
            </div>
        </form>
    </div>

    <!-- Подсказки -->
    <div style="margin-top: 20px; padding: 15px; background-color: #fff3cd; border-radius: 8px; color: #856404;">
        <strong>💡 Подсказка:</strong> Все поля с звездочкой (*) обязательны для заполнения.
        Остальные поля можно оставить пустыми.
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Предпросмотр фото
            const photoInput = document.getElementById('photoUrl');
            const previewDiv = document.querySelector('.photo-preview');

            if (photoInput && previewDiv) {
                photoInput.addEventListener('input', function (e) {
                    const url = e.target.value;
                    if (url && (url.startsWith('http') || url.startsWith('https'))) {
                        previewDiv.innerHTML = `<img src="${url}" alt="Preview" style="max-width: 100%; max-height: 200px; border-radius: 8px;">`;
                    } else {
                        previewDiv.innerHTML = `
                                    <div class="photo-placeholder">
                                        <span>🖼️</span>
                                        Предпросмотр фото будет здесь
                                    </div>`;
                    }
                });
            }

            // Счетчик символов для полного описания
            const fullDesc = document.getElementById('FullDescription');
            const counter = document.getElementById('charCounter');

            if (fullDesc && counter) {
                fullDesc.addEventListener('input', function () {
                    const length = this.value.length;
                    counter.textContent = length + ' / 2000 символов';

                    if (length > 1800) {
                        counter.style.color = '#e74c3c';
                    } else {
                        counter.style.color = '#999';
                    }
                });
            }
        });
    </script>
}
