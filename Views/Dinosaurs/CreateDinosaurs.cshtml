@* Views/Dinosaurs/CreateDinosaurs.cshtml *@
@model DinoApp.Models.CreateDinosaurDto

@{
    ViewData["Title"] = "Создание динозавра";
}

<!-- Стили остаются теми же -->

<div class="create-container">
    <div class="page-header">
        <div class="dino-avatar">
            🦖
        </div>
        <h1>👷 Создание нового динозавра</h1>
    </div>

    <div class="form-card">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary" style="display: block;">
                ⚠️ Пожалуйста, исправьте ошибки в форме
            </div>
        }

        <!-- ВАЖНО: Добавляем enctype="multipart/form-data" -->
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Остальные поля остаются теми же -->
            <!-- Загрузка фото - ИЗМЕНЕНО -->
            <div class="form-group">
                <label asp-for="PhotoFile" class="form-label">
                    <i>📸</i> Фотография динозавра
                </label>
                <input asp-for="PhotoFile" type="file" class="form-control" accept="image/*" id="photoFile">
                <span asp-validation-for="PhotoFile" class="field-validation"></span>

                <div class="photo-preview" id="photoPreview">
                    <div class="photo-placeholder">
                        <span>🖼️</span>
                        Предпросмотр фото будет здесь
                    </div>
                </div>
                <div class="tooltip-info">
                    <i>ℹ️</i> Загрузите изображение динозавра (JPG, PNG, GIF до 5MB)
                </div>
            </div>

            <!-- Остальные поля остаются теми же -->
            <!-- Кнопки действий -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    💾 Создать динозавра
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    ↩️ Отмена
                </a>
                <button type="reset" class="btn btn-danger">
                    🗑️ Очистить
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Предпросмотр фото для файла
            const photoInput = document.getElementById('photoFile');
            const previewDiv = document.getElementById('photoPreview');

            if (photoInput && previewDiv) {
                photoInput.addEventListener('change', function (e) {
                    const file = e.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            previewDiv.innerHTML = `<img src="${e.target.result}" alt="Preview" style="max-width: 100%; max-height: 200px; border-radius: 8px;">`;
                        }
                        reader.readAsDataURL(file);
                    } else {
                        previewDiv.innerHTML = `
                                    <div class="photo-placeholder">
                                        <span>🖼️</span>
                                        Предпросмотр фото будет здесь
                                    </div>`;
                    }
                });
            }

            // Остальной JavaScript (счетчик символов и т.д.)
        });
    </script>
}