@model DinoApp.Models.User

@{
    ViewData["Title"] = $"Профиль: {Model.Username}";
    var isOwnProfile = ViewBag.IsOwnProfile == true;
    var stats = ViewBag.UserStats as DinoApp.Controllers.UserStats;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #1a472a 0%, #2d5a3b 100%);
        min-height: 100vh;
    }

    .profile-container {
        max-width: 1000px;
        margin: 40px auto;
        padding: 20px;
    }

    .profile-card {
        background: white;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 215, 0, 0.3);
    }

    /* Шапка профиля */
    .profile-header {
        background: linear-gradient(135deg, #2c5a1e, #1a472a);
        padding: 40px;
        text-align: center;
        color: white;
        position: relative;
    }

    .avatar {
        width: 150px;
        height: 150px;
        margin: 0 auto 20px;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #ffd700;
        background: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar .no-avatar {
        font-size: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
    }

    .profile-header h1 {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .profile-header .username {
        font-size: 16px;
        opacity: 0.9;
        margin-bottom: 15px;
    }

    .admin-badge {
        display: inline-block;
        padding: 5px 15px;
        background: #ffd700;
        color: #2c5a1e;
        border-radius: 20px;
        font-size: 12px;
        font-weight: bold;
        margin-top: 10px;
    }

    .edit-profile-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.5);
        color: white;
        padding: 8px 16px;
        border-radius: 25px;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s;
    }

    .edit-profile-btn:hover {
        background: #ffd700;
        color: #2c5a1e;
        border-color: #ffd700;
    }

    /* Статистика */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        padding: 30px;
        background: #f8f9fa;
        border-bottom: 1px solid #eee;
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        font-size: 28px;
        font-weight: bold;
        color: #2c5a1e;
    }

    .stat-label {
        font-size: 14px;
        color: #666;
        margin-top: 5px;
    }

    /* Тело профиля */
    .profile-body {
        padding: 30px;
    }

    .info-section {
        margin-bottom: 30px;
    }

    .info-section h3 {
        color: #2c5a1e;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #ffd700;
        display: inline-block;
    }

    .info-row {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .info-label {
        width: 150px;
        font-weight: 600;
        color: #555;
    }

    .info-value {
        flex: 1;
        color: #333;
    }

    .bio-text {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 15px;
        line-height: 1.6;
        color: #555;
        margin-top: 10px;
    }

    /* Кнопки действий */
    .action-buttons {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #eee;
    }

    .btn {
        padding: 10px 25px;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background: #2c5a1e;
        color: white;
    }

    .btn-primary:hover {
        background: #ffd700;
        color: #2c5a1e;
        transform: translateY(-2px);
    }

    .btn-secondary {
        background: #95a5a6;
        color: white;
    }

    .btn-secondary:hover {
        background: #7f8c8d;
        transform: translateY(-2px);
    }

    /* Уведомления */
    .alert {
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border-left: 4px solid #28a745;
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .profile-container {
            margin: 20px auto;
            padding: 10px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .info-row {
            flex-direction: column;
        }

        .info-label {
            width: auto;
            margin-bottom: 5px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn {
            justify-content: center;
        }

        .edit-profile-btn {
            position: static;
            margin-top: 15px;
            display: inline-block;
        }
    }
</style>

<div class="profile-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            ✅ @TempData["SuccessMessage"]
        </div>
    }

    <div class="profile-card">
        <div class="profile-header">
            @if (isOwnProfile)
            {
                <a asp-action="EditProfile" class="edit-profile-btn">✏️ Редактировать профиль</a>
            }

            <div class="avatar">
                @if (!string.IsNullOrEmpty(Model.AvatarUrl) && Model.AvatarUrl != "/images/default-avatar.png")
                {
                    <img src="@Model.AvatarUrl" alt="@Model.Username" onerror="this.src='/images/default-avatar.png'">
                }
                else
                {
                    <div class="no-avatar">🦖</div>
                }
            </div>

            <h1>@(Model.FullName ?? Model.Username)</h1>
            <div class="username">@@@Model.Username</div>

            @if (Model.IsAdmin)
            {
                <div class="admin-badge">⭐ Администратор</div>
            }
        </div>

        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-value">@stats?.MemberDays ?? 0</div>
                <div class="stat-label">Дней в Dino_Mir</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">@Model.DinosaursCreated</div>
                <div class="stat-label">Создано динозавров</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">@Model.CommentsCount</div>
                <div class="stat-label">Комментариев</div>
            </div>
        </div>

        <div class="profile-body">
            <div class="info-section">
                <h3>📋 Основная информация</h3>

                <div class="info-row">
                    <div class="info-label">Имя пользователя:</div>
                    <div class="info-value">@@@Model.Username</div>
                </div>

                @if (!string.IsNullOrEmpty(Model.FullName))
                {
                    <div class="info-row">
                        <div class="info-label">Полное имя:</div>
                        <div class="info-value">@Model.FullName</div>
                    </div>
                }

                <div class="info-row">
                    <div class="info-label">Email:</div>
                    <div class="info-value">
                        @Model.Email
                        @if (!isOwnProfile)
                        {
                            <span style="color: #999; font-size: 12px;"> (скрыт)</span>
                        }
                    </div>
                </div>

                <div class="info-row">
                    <div class="info-label">Дата регистрации:</div>
                    <div class="info-value">@Model.CreatedAt.ToString("dd MMMM yyyy")</div>
                </div>

                @if (Model.LastLoginAt.HasValue)
                {
                    <div class="info-row">
                        <div class="info-label">Последний визит:</div>
                        <div class="info-value">@Model.LastLoginAt.Value.ToString("dd MMMM yyyy HH:mm")</div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Bio))
            {
                <div class="info-section">
                    <h3>📝 О себе</h3>
                    <div class="bio-text">
                        @Model.Bio
                    </div>
                </div>
            }

            <div class="action-buttons">
                <a href="/" class="btn btn-secondary">🏠 На главную</a>
                <a asp-controller="Dinosaurs" asp-action="Index" class="btn btn-secondary">🦕 К динозаврам</a>
                @if (isOwnProfile)
                {
                    <a asp-action="EditProfile" class="btn btn-primary">✏️ Редактировать профиль</a>
                    <a asp-action="Logout" class="btn btn-secondary" style="background: #e74c3c;">🚪 Выйти</a>
                }
            </div>
        </div>
    </div>
</div>