@{
    ViewData["Title"] = "О проекте Dino_Mir";
}

<div class="main-container">
    <div class="hero-section">
        <h1>🦕 О проекте Dino_Mir</h1>
        <p style="font-size: 18px; color: #555;">Узнайте больше о нашем проекте</p>
    </div>

    <div class="card" style="padding: 40px;">
        <div style="max-width: 800px; margin: 0 auto;">
            <h2 style="color: #2c5a1e; margin-bottom: 30px;">🌍 Добро пожаловать в мир динозавров!</h2>

            <p style="font-size: 16px; line-height: 1.8; color: #444; margin-bottom: 20px;">
                Dino_Mir — это образовательный проект, созданный для всех, кто интересуется древними
                рептилиями и историей нашей планеты. Мы собрали обширную базу данных о динозаврах
                со всего мира.
            </p>

            <h3 style="color: #2c5a1e; margin: 30px 0 20px;">📚 Наша миссия</h3>
            <p style="font-size: 16px; line-height: 1.8; color: #444; margin-bottom: 20px;">
                Мы стремимся популяризировать науку и вдохновлять новое поколение исследователей.
            </p>

            <div style="text-align: center; margin-top: 40px;">
                <a href="/" class="btn-dino btn-dino-primary">🏠 На главную</a>
            </div>
        </div>
    </div>
</div>
