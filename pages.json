  {
    "Id": 4,
    "Title": "\u0423\u0441\u043B\u043E\u0432\u0438\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F",
    "Slug": "Terms",
    "Content": "\u0412\u044B \u043A\u0430\u043A \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C \u044D\u0442\u043E\u0433\u043E \u0441\u0430\u0439\u0442\u0430 \u0434\u043E\u043B\u0436\u043D\u044B \u0441\u043E\u0431\u043B\u044E\u0434\u0430\u0442\u044C \u043F\u0440\u0430\u0432\u0438\u043B\u0430 Dino_Mir \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F \u0438\u043C. \u0412\u043E\u0442 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0439 \u0441\u043F\u0438\u0441\u043E\u043A \u043F\u0440\u0430\u0432\u0438\u043B Dino_Mir:\r\n1. \u041D\u0438\u043A\u0430\u043A\u043E\u0433\u043E \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0430 --- \u043F\u043E\u043F\u044B\u0442\u043A\u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u0431\u0443\u0434\u0443\u0442 \u043D\u0430\u0439\u0434\u0435\u043D\u044B \u0438 \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0435\u043D\u044B. \r\n2. \u041F\u0440\u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u044B \u043D\u0435\u043B\u044C\u0437\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u043D\u0435\u0446\u0435\u043D\u0437\u0443\u0440\u043D\u0443\u044E \u0431\u0440\u0430\u043D\u044C, \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435 \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u043D\u0435\u043F\u0440\u0438\u0441\u0442\u043E\u0439\u043D\u043E\u0433\u043E \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u044F, \u043F\u0440\u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u0434\u0438\u043D\u043E\u0437\u0430\u0432\u0440\u0430 \u0434\u043E\u043B\u0436\u043D\u0430 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442\u044C \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E \u043F\u0440\u043E \u0434\u0438\u043D\u043E\u0437\u0430\u0432\u0440\u043E\u0432 (\u0432 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438  \u043D\u0435 \u0432 \u0449\u0451\u0442).\r\n3.\u041F\u0440\u0438 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438 \u043D\u0435\u043B\u044C\u0437\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u043D\u0435\u0446\u0435\u043D\u0437\u0443\u0440\u043D\u0443\u044E \u0431\u0440\u0430\u043D\u044C, \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C \u0441\u0432\u043E\u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435,\u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043C\u0435\u0448\u0430\u044E\u0449\u0438\u0435 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u0438 \u0441\u043E\u0434\u0440\u0443\u0436\u0435\u0441\u0442\u0432\u0443.\r\n4.\u0411\u0443\u0434\u044C \u0432\u0435\u0436\u043B\u0438\u0432\u044B \u0438 \u0434\u043E\u0431\u0440\u044B \u043A \u043B\u044E\u0434\u044F\u043C.",
